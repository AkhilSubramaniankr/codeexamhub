# FastAPI Configuration
PORT=8000
ENV=development
JWT_SECRET=super-secret-jwt-key-for-development-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Connections
# For Docker environment, use service names (db, mongodb, redis)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/codeexamhub
MONGODB_URI=mongodb://mongodb:27017/codeexamhub
REDIS_URL=redis://redis:6379/0

# For local development outside Docker (uncomment if running outside Docker):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codeexamhub
# MONGODB_URI=mongodb://localhost:27017/codeexamhub
# REDIS_URL=redis://localhost:6379/0

# Frontend URL
FRONTEND_URL=http://localhost:3000
